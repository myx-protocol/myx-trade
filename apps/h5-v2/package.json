    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "4.0.8",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.0",
    "prettier": "^3.6.2",
