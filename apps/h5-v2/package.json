    "html-to-image": "^1.11.13",
    "immer": "^10.1.3",
    "keccak": "^3.0.4",
    "lodash-es": "^4.17.21",
    "mitt": "^3.0.1",
    "pnpm": "^10.21.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-fast-marquee": "^1.6.5",
