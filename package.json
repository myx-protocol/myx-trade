{
  "name": "@myx-trade/sdk",
  "version": "1.0.19-beta.2",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "MYX Trade SDK for trading operations",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./lp": {
      "types": "./dist/lp.d.ts",
      "import": "./dist/lp.mjs",
      "require": "./dist/lp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx scripts/build.ts --watch",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "prepublishOnly": "pnpm run build",
    "gen:abi": "typechain --target ethers-v6 --out-dir ./src/abi/types './src/abi/**/*.json'",
    "custom-publish": "tsx scripts/customPublish.ts",
    "push:public": "bash scripts/push-to-public-remote.sh",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "trading",
    "sdk",
    "myx",
    "finance"
  ],
  "author": "",
  "license": "ISC",
  "sideEffects": false,
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@typechain/ethers-v6": "^0.5.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "crypto-es": "^3.1.3",
    "dayjs": "^1.11.13",
    "ethers-decode-error": "^2.1.3",
    "inquirer": "^13.2.0",
    "lodash-es": "^4.17.21",
    "mitt": "^3.0.1",
    "reconnecting-websocket": "^4.4.0",
    "viem": "^2.36.0",
    "wretch": "^2.11.0",
    "ws": "^8.18.3"
  }
}
