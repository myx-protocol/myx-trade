{
  "name": "myx-sdk",
  "version": "1.0.0",
  "description": "React + Vite + TypeScript SDK",
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "main": "dist/index/index.cjs.js",
  "module": "dist/index/index.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index/index.es.js",
      "require": "./dist/index/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.es.js",
      "require": "./dist/components/index.cjs.js",
      "types": "./dist/types/components/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.es.js",
      "require": "./dist/utils/index.cjs.js",
      "types": "./dist/types/utils/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@typechain/ethers-v6": "^0.5.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typechain": "^8.3.2",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "gen:abi": "typechain --target ethers-v6 --out-dir src/abi/types './src/abi/**/*.json'"
  },
  "dependencies": {
    "@ethersproject/providers": "^5.8.0",
    "ethers": "^6.15.0",
    "ethers-decode-error": "^2.1.3",
    "lodash-es": "^4.17.21"
  }
}
