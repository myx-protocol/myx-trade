{
  "name": "@myx",
  "version": "0.1.1",
  "description": "MYX Trade SDK monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "clean": "pnpm -r clean",
    "build:sdk": "cd packages/sdk && pnpm build",
    "install:sdk": "cd packages/sdk && pnpm install",
    "install:playground": "cd packages/playground && pnpm install",
    "dev:playground": "cd packages/playground && pnpm dev",
    "build:playground": "cd packages/playground && pnpm build",
    "gen:abi": "cd packages/sdk && pnpm run gen:abi",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "type-check": "turbo run type-check"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@wagmi/core": "^2.20.3",
    "crypto-js": "^4.2.0",
    "eslint": "^9.39.1",
    "swr": "^2.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "turbo": "^2.6.1",
    "typescript": "~5.8.3"
  }
}
